TD_tb_keypad_controller.simulate_keystroke ;
    %vpi_call 2 50 "$display", "[SIM] Activating Switch Location: Row %0d, Col %0d", v0000020c7dc53940_0, v0000020c7dc545c0_0 {0 0 0};
    %load/vec4 v0000020c7dc53940_0;
    %store/vec4 v0000020c7dcd4f60_0, 0, 2;
    %load/vec4 v0000020c7dc545c0_0;
    %store/vec4 v0000020c7dcd5280_0, 0, 2;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0000020c7dcd38e0_0, 0, 1;
    %load/vec4 v0000020c7dc53800_0;
    %muli 1000, 0, 32;
    %pad/s 64;
    %muli 1000, 0, 64;
    %ix/vec4 4;
    %delayx 4;
    %vpi_call 2 58 "$display", "[SIM] Releasing Switch Location: Row %0d, Col %0d", v0000020c7dc53940_0, v0000020c7dc545c0_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0000020c7dcd38e0_0, 0, 1;
    %delay 200000000, 0;
    %end;
